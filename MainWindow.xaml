<Window x:Class="AutoShutdownModernized.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}"
        Width="320"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable Text, Segoe UI">
    
    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2B93FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0066CC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="CancelBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#333333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#262626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TumblerListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="Transparent" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="24"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimeSpinnerBtn" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="#0A84FF"/>
                                <Setter Property="Background" Value="#262626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="#171717" CornerRadius="14" BorderBrush="#2C2C2C" BorderThickness="1">
        <Grid Margin="20,20,20,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0"
                  Margin="0,0,0,18"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource MainHeader}"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        Foreground="#D8D8D8"
                        BorderThickness="0"
                        Padding="0"
                        Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="x" />
                            <Setter Property="FontSize" Value="20" />
                            <Setter Property="ToolTip" Value="{DynamicResource CloseButtonTooltip}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsScheduled}" Value="True">
                                    <Setter Property="Content" Value="_" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="ToolTip" Value="{DynamicResource TrayButtonTooltip}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2E2E2E"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#3C3C3C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Configuration Mode -->
            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScheduled}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="{DynamicResource ScheduleShutdownText}"
                           Foreground="#B8B8B8"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,2" />
                <TextBlock Text="{DynamicResource TimeFormatLabel}"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10" />
                
                <Grid
                    Margin="0,0,0,14"
                      HorizontalAlignment="Center"
                      PreviewMouseWheel="TimeSelectionGrid_PreviewMouseWheel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Grid.ColumnSpan="5" Height="50" Background="#262626" CornerRadius="6" VerticalAlignment="Center" IsHitTestVisible="False"/>

                    <Border Grid.Column="0" Background="Transparent" Tag="H">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <RepeatButton Grid.Row="0" Content="⌃" Command="{Binding AdjustTimeCommand}" CommandParameter="H+" Style="{StaticResource TimeSpinnerBtn}"/>
                            <TextBlock Grid.Row="1" Text="{Binding SelectedHours, StringFormat={}{0:D2}}" FontSize="28" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <RepeatButton Grid.Row="2" Content="⌄" Command="{Binding AdjustTimeCommand}" CommandParameter="H-" Style="{StaticResource TimeSpinnerBtn}"/>
                        </Grid>
                    </Border>
                    
                    <TextBlock Grid.Column="1" Text=":" FontSize="28" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    
                    <Border Grid.Column="2" Background="Transparent" Tag="M">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <RepeatButton Grid.Row="0" Content="⌃" Command="{Binding AdjustTimeCommand}" CommandParameter="M+" Style="{StaticResource TimeSpinnerBtn}"/>
                            <TextBlock Grid.Row="1" Text="{Binding SelectedMinutes, StringFormat={}{0:D2}}" FontSize="28" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <RepeatButton Grid.Row="2" Content="⌄" Command="{Binding AdjustTimeCommand}" CommandParameter="M-" Style="{StaticResource TimeSpinnerBtn}"/>
                        </Grid>
                    </Border>
                    
                    <TextBlock Grid.Column="3" Text=":" FontSize="28" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    
                    <Border Grid.Column="4" Background="Transparent" Tag="S">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <RepeatButton Grid.Row="0" Content="⌃" Command="{Binding AdjustTimeCommand}" CommandParameter="S+" Style="{StaticResource TimeSpinnerBtn}"/>
                            <TextBlock Grid.Row="1" Text="{Binding SelectedSeconds, StringFormat={}{0:D2}}" FontSize="28" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <RepeatButton Grid.Row="2" Content="⌄" Command="{Binding AdjustTimeCommand}" CommandParameter="S-" Style="{StaticResource TimeSpinnerBtn}"/>
                        </Grid>
                    </Border>
                </Grid>

                <Button Content="{DynamicResource StartButtonText}"
                        Command="{Binding StartShutdownCommand}"
                        Height="44"
                        Style="{StaticResource PrimaryBtn}" />
            </StackPanel>

            <!-- Countdown Mode -->
            <StackPanel Grid.Row="1">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScheduled}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="{DynamicResource CountdownText}"
                           Foreground="#B8B8B8"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding RemainingTimeText}"
                           FontSize="30"
                           FontWeight="Light"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,14" />
                <Button Content="{DynamicResource CancelButtonText}"
                        Command="{Binding CancelShutdownCommand}"
                        Height="44"
                        Style="{StaticResource CancelBtn}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
